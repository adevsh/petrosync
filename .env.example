# Database (matches docker-compose postgres service)
DATABASE_URL=postgres://petrosync_app:petrosync_dev@localhost:5432/petrosync?sslmode=disable

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-64-char-random-string

# Valkey (matches docker-compose valkey service)
VALKEY_ADDR=localhost:6379

# Telegram Bot (set your bot token from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Garage — copy Access Key ID + Secret Key from `docker compose up` output
# (garage-init container prints them on first run)
GARAGE_ENDPOINT=http://localhost:3900
GARAGE_ACCESS_KEY=GK...
GARAGE_SECRET_KEY=...
GARAGE_BUCKET=petrosync

# Application
APP_ENV=development
APP_PORT=8080
